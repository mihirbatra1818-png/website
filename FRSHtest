function addNewProduct() {
  const code = document.getElementById('new-product-code').value.trim();
  const name = document.getElementById('new-product-name').value.trim();
  const desc = document.getElementById('new-product-desc').value.trim();
  const category = document.getElementById('new-product-category').value;
  const priceVal = document.getElementById('new-product-price').value;
  const salePriceVal = document.getElementById('new-product-sale-price').value;
  const emoji = document.getElementById('new-product-emoji').value.trim();

  if (!code || !name || !desc || !category || !priceVal || !emoji) {
    showToast('Please fill in all required fields', '#FF6B6B');
    return;
  }

  const price = parseFloat(priceVal);
  const salePrice = salePriceVal ? parseFloat(salePriceVal) : null;

  if (isNaN(price) || price <= 0 || (salePrice && isNaN(salePrice))) {
    showToast('Invalid price values', '#FF6B6B');
    return;
  }

  const newProduct = {
    id: 'custom_' + Date.now(),
    name: name,
    desc: desc,
    price: price,
    salePrice: salePrice,
    category: category,
    onSale: salePrice ? true : false,
    emoji: emoji,
    isCustom: true
  };

  customProducts.push(newProduct);
 
  // Clear form
  document.getElementById('new-product-code').value = '';
  document.getElementById('new-product-name').value = '';
  document.getElementById('new-product-desc').value = '';
  document.getElementById('new-product-category').value = '';
  document.getElementById('new-product-price').value = '';
  document.getElementById('new-product-sale-price').value = '';
  document.getElementById('new-product-emoji').value = '';

  renderManageProducts();
  renderCatalog('all');
  showToast(`Product "${name}" added! It's now in your catalog.`, '#4ECDC4');
}

function deleteProduct(productId) {
  customProducts = customProducts.filter(p => p.id !== productId);
  renderManageProducts();
  renderCatalog('all');
  renderDeals();
  showToast('Product deleted', '#FF6B6B');
}


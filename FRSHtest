async function addToCart() {
  if (!currentProduct) return;
  if (cartItems.length >= 999) { showToast('Cart limit reached (999 items)', '#FF6B6B'); return; }
  const btn = document.getElementById('add-to-cart-btn');
  btn.textContent = 'Adding...'; btn.disabled = true;

  const price = currentProduct.onSale && currentProduct.salePrice ? currentProduct.salePrice : currentProduct.price;
  const result = await window.dataSdk.create({
    product_id: currentProduct.id,
    product_name: currentProduct.name,
    garment: mockupState.garment,
    size: mockupState.size,
    color: mockupState.color,
    quantity: mockupState.qty,
    price: price,
    shipping: 'regular',
    mockup_text: mockupState.text,
    mockup_text_color: mockupState.textColor,
    mockup_design_x: 0,
    mockup_design_y: 0,

function renderCart() {
  const itemsDiv = document.getElementById('cart-items');
  const emptyDiv = document.getElementById('cart-empty');
  const summaryDiv = document.getElementById('cart-summary');
  const activeItems = cartItems.filter(i => i.status === 'cart');

  if (activeItems.length === 0) {
    emptyDiv.style.display = 'block'; summaryDiv.style.display = 'none'; itemsDiv.innerHTML = '';
    return;
  }
  emptyDiv.style.display = 'none'; summaryDiv.style.display = 'block';

  const existingEls = new Map([...itemsDiv.children].map(el => [el.dataset.id, el]));
  const newIds = new Set(activeItems.map(i => i.__backendId));

  activeItems.forEach(item => {
    const gt = GARMENT_TYPES.find(g => g.id === item.garment);
    if (existingEls.has(item.__backendId)) {
      const el = existingEls.get(item.__backendId);
      el.querySelector('.cart-item-name').textContent = item.product_name;
      el.querySelector('.cart-item-details').textContent = `${gt ? gt.label : item.garment} · ${item.size} · Qty: ${item.quantity}`;
      el.querySelector('.cart-item-price').textContent = `$${(item.price * item.quantity).toFixed(2)}`;
      el.querySelector('.cart-item-thumb').innerHTML = garmentThumb(item.garment, item.color, 50);
      el.querySelector('.cart-item-mockup').textContent = item.mockup_text ? `"${item.mockup_text}"` : '';
      existingEls.delete(item.__backendId);
    } else {
      const el = document.createElement('div');
      el.dataset.id = item.__backendId;
      el.className = 'flex items-center gap-4 p-4 rounded-xl';
      el.style.cssText = 'background:#fff; box-shadow: 0 2px 12px rgba(0,0,0,0.05);';
      el.innerHTML = `
        <div class="cart-item-thumb flex-shrink-0">${garmentThumb(item.garment, item.color, 50)}</div>
        <div class="flex-1 min-w-0">
          <p class="cart-item-name font-bold text-sm" style="color:#333;">${item.product_name}</p>
          <p class="cart-item-details text-xs text-gray-400">${gt ? gt.label : item.garment} · ${item.size} · Qty: ${item.quantity}</p>
          <p class="cart-item-mockup text-xs mt-1" style="color:#4ECDC4;">${item.mockup_text ? `"${item.mockup_text}"` : ''}</p>
        </div>
        <div class="text-right flex-shrink-0">
          <p class="cart-item-price font-bold" style="color:#FF6B6B;">$${(item.price * item.quantity).toFixed(2)}</p>
          <button onclick="removeCartItem('${item.__backendId}')" class="text-xs text-gray-400 hover:text-red-500 mt-1">Remove</button>
        </div>`;
      itemsDiv.appendChild(el);
    }
  });

  existingEls.forEach(el => el.remove());
  updateCartTotals(activeItems);
}

async function removeCartItem(backendId) {
  const item = cartItems.find(i => i.__backendId === backendId);
  if (!item) return;
  const result = await window.dataSdk.delete(item);
  if (!result.isOk) showToast('Failed to remove item', '#FF6B6B');
}

function updateCartTotals(items) {
  const subtotal = items.reduce((s, i) => s + i.price * i.quantity, 0);
  const shipCost = shippingMethod === 'superfast' ? 12.99 : 0;
 
  // Calculate discount
  let discount = 0;
  if (appliedPromoCode && PROMO_CODES[appliedPromoCode]) {
    const promo = PROMO_CODES[appliedPromoCode];
    if (promo.type === 'percent') {
      discount = (subtotal * promo.value) / 100;
    } else if (promo.type === 'fixed') {
      discount = Math.min(promo.value, subtotal);
    }
  }
  promoDiscount = discount;
 
  const discountedSubtotal = subtotal - discount;
  const total = discountedSubtotal + shipCost;
 
  document.getElementById('cart-subtotal').textContent = '$' + subtotal.toFixed(2);
  document.getElementById('cart-shipping').textContent = shipCost > 0 ? '$12.99' : 'Free';
  document.getElementById('cart-shipping').style.color = shipCost > 0 ? '#FF6B6B' : '#4ECDC4';
  document.getElementById('cart-total').textContent = '$' + total.toFixed(2);
 
  // Show/hide promo discount row
  const promoRow = document.getElementById('promo-discount-row');
  if (discount > 0) {
    promoRow.style.display = 'block';
    document.getElementById('promo-discount-display').textContent = '-$' + discount.toFixed(2);
  } else {
    promoRow.style.display = 'none';
  }
}

function updateShipping() {
  const radios = document.querySelectorAll('input[name="shipping"]');
  radios.forEach(r => {
    const label = r.closest('label');
    if (r.checked) {
      shippingMethod = r.value;
      label.style.borderColor = r.value === 'superfast' ? '#FF6B6B' : '#4ECDC4';
      label.style.background = r.value === 'superfast' ? '#fff5f5' : '#f0fffe';
    } else {
      label.style.borderColor = '#eee'; label.style.background = '#fff';
    }
  });
  const activeItems = cartItems.filter(i => i.status === 'cart');
  updateCartTotals(activeItems);
}

function applyPromoCode() {
  const input = document.getElementById('promo-code-input');
  const code = input.value.toUpperCase().trim();
  const messageDiv = document.getElementById('promo-message');
 
  if (!code) {
    messageDiv.style.display = 'none';
    return;
  }
 
  if (PROMO_CODES[code]) {
    appliedPromoCode = code;
    const promo = PROMO_CODES[code];
    messageDiv.textContent = `✓ ${promo.description}`;
    messageDiv.style.background = '#d4edda';
    messageDiv.style.color = '#155724';
    messageDiv.style.display = 'block';
    const activeItems = cartItems.filter(i => i.status === 'cart');
    updateCartTotals(activeItems);
    showToast(`Promo code "${code}" applied!`, '#4ECDC4');
  } else {
    messageDiv.textContent = '✗ Invalid promo code';
    messageDiv.style.background = '#f8d7da';
    messageDiv.style.color = '#721c24';
    messageDiv.style.display = 'block';
    showToast('Promo code not found', '#FF6B6B');
  }
}

function initiatePayment() {
  const activeItems = cartItems.filter(i => i.status === 'cart');
  if (activeItems.length === 0) return;
 
  // Mount card element when showing form
  if (cardElement && !cardElement._isMounted) {
    cardElement.mount('#card-element');
    cardElement.on('change', (event) => {
      const displayError = document.getElementById('card-errors');
      if (event.error) {
        displayError.textContent = event.error.message;
      } else {
        displayError.textContent = '';
      }
    });
  }
 
  document.getElementById('place-order-btn').style.display = 'none';
  document.getElementById('payment-form-container').style.display = 'block';
  window.scrollTo(0, document.getElementById('payment-form-container').offsetTop - 100);
}

function cancelPayment() {
  document.getElementById('payment-form-container').style.display = 'none';
  document.getElementById('place-order-btn').style.display = 'block';
  document.getElementById('card-errors').textContent = '';
  if (cardElement) cardElement.clear();
}

async function handlePayment(event) {
  event.preventDefault();

  const btn = document.getElementById('submit-payment');
  btn.disabled = true;
  btn.textContent = 'Processing...';

  const activeItems = cartItems.filter(i => i.status === 'cart');
  const subtotal = activeItems.reduce((s, i) => s + i.price * i.quantity, 0);
  const shipCost = shippingMethod === 'superfast' ? 12.99 : 0;
  const discount = promoDiscount;
  const total = Math.round((subtotal - discount + shipCost) * 100); // in cents

  try {
    // Create payment method with Stripe
    const { paymentMethod, error } = await stripe.createPaymentMethod({
      type: 'card',
      card: cardElement,
    });

    if (error) {
      document.getElementById('card-errors').textContent = error.message;
      btn.disabled = false;
      btn.textContent = 'Complete Payment';
      return;
    }

    // In production, send paymentMethod.id to your backend to create charge
    // For now, we'll simulate successful payment
    await new Promise(r => setTimeout(r, 1500));
   
    showToast('💳 Payment processed with Stripe!', '#4ECDC4');
   
    // Mark items as ordered
    let allOk = true;
    for (const item of activeItems) {
      const result = await window.dataSdk.update({ ...item, status: 'ordered' });
      if (!result.isOk) allOk = false;
    }

    if (allOk) {
      const orderNumber = Math.random().toString(36).substr(2, 9).toUpperCase();
      showToast(`🎉 Order #${orderNumber} confirmed!`, '#4ECDC4');
      cancelPayment();
      setTimeout(() => navigateTo('deals'), 2000);
    } else {
      showToast('Payment successful but order save failed', '#FF6B6B');
    }
  } catch (err) {
    document.getElementById('card-errors').textContent = 'Payment error: ' + err.message;
    btn.disabled = false;
    btn.textContent = 'Complete Payment';
  }
}

function updateCartBadge() {

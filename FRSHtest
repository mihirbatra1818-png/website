<!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Apparel Store</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>
  <script src="https://js.stripe.com/v3/"></script>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&amp;family=Space+Mono:wght@400;700&amp;display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; font-family: 'Outfit', sans-serif; }
    .page { display: none; }
    .page.active { display: block; }
    .nav-link { position: relative; cursor: pointer; transition: color 0.2s; }
    .nav-link::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 2px; transition: width 0.3s; }
    .nav-link:hover::after, .nav-link.active::after { width: 100%; }
    .product-card { transition: transform 0.3s, box-shadow 0.3s; }
    .product-card:hover { transform: translateY(-6px); }
    .garment-svg { transition: all 0.3s; }
    .toast-container { position: fixed; top: 20px; right: 20px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
    .toast { padding: 14px 20px; border-radius: 12px; color: #fff; font-weight: 500; animation: slideIn 0.4s ease, fadeOut 0.4s ease 2.6s; opacity: 0; animation-fill-mode: forwards; }
    @keyframes slideIn { from { transform: translateX(100px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    @keyframes fadeOut { from { opacity: 1; } to { opacity: 0; } }
    .mockup-canvas { position: relative; overflow: hidden; border-radius: 12px; }
    .deal-badge { animation: pulse 2s infinite; }
    @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
    .hero-gradient { background: linear-gradient(135deg, #FF6B6B 0%, #FFE66D 25%, #4ECDC4 50%, #45B7D1 75%, #96E6A1 100%); background-size: 300% 300%; animation: gradientMove 8s ease infinite; }
    @keyframes gradientMove { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
    .confirm-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9998; display: flex; align-items: center; justify-content: center; }
    .stagger-in { opacity: 0; transform: translateY(20px); animation: staggerReveal 0.6s ease forwards; }
    @keyframes staggerReveal { to { opacity: 1; transform: translateY(0); } }
    input[type="range"] { -webkit-appearance: none; height: 6px; border-radius: 3px; outline: none; }
    input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 18px; height: 18px; border-radius: 50%; cursor: pointer; }
  </style>
  <style>body { box-sizing: border-box; }</style>
 </head>
 <body class="h-full">
  <div id="app" class="h-full w-full overflow-auto" style="background: #FAFAFA;">
   <!-- Toast Container -->
   <div id="toast-container" class="toast-container"></div><!-- Confirm Overlay -->
   <div id="confirm-overlay" class="confirm-overlay" style="display:none;"></div><!-- Navigation -->
   <nav id="main-nav" style="background: #fff; border-bottom: 2px solid #FF6B6B;" class="sticky top-0 z-50 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
     <div class="flex items-center justify-between h-16">
      <div id="nav-brand" class="font-bold text-xl tracking-tight" style="color: #FF6B6B; font-family: 'Space Mono', monospace;">
       FRSH CO.
      </div>
      <div class="flex items-center gap-2"><button id="menu-btn" class="flex items-center justify-center w-10 h-10 rounded-lg hover:bg-gray-100 transition" onclick="toggleMenu()"><i data-lucide="menu" style="color:#333; width:24px; height:24px;"></i></button>
      </div>
     </div>
     <div id="nav-menu" class="absolute top-16 right-0 w-full max-w-xs bg-white rounded-b-2xl shadow-lg p-4" style="display:none; border-top: 1px solid #eee;">
      <div class="flex flex-col gap-2">
       <span class="nav-link block px-4 py-3 rounded-lg text-sm font-medium cursor-pointer transition" data-page="home" onclick="navigateTo('home');closeMenu()" style="color: #333; background: #f7f7f7;">HOME</span> <span class="nav-link block px-4 py-3 rounded-lg text-sm font-medium cursor-pointer transition" data-page="deals" onclick="navigateTo('deals');closeMenu()" style="color: #333; background: #f7f7f7;">DEALS</span> <span class="nav-link block px-4 py-3 rounded-lg text-sm font-medium cursor-pointer transition" data-page="catalog" onclick="navigateTo('catalog');closeMenu()" style="color: #333; background: #f7f7f7;">CATALOG</span> <span class="nav-link block px-4 py-3 rounded-lg text-sm font-medium cursor-pointer transition" data-page="about" onclick="navigateTo('about');closeMenu()" style="color: #333; background: #f7f7f7;">ABOUT</span> <span class="nav-link block px-4 py-3 rounded-lg text-sm font-medium cursor-pointer transition relative" data-page="cart" onclick="navigateTo('cart');closeMenu()" style="color: #333; background: #f7f7f7;"> CART <span id="cart-badge" class="inline-block ml-2 text-white text-xs px-2 py-1 rounded-full" style="background:#FF6B6B; display:none;">0</span> </span> <span class="nav-link flex items-center gap-2 px-4 py-3 rounded-lg text-sm font-medium cursor-pointer transition" data-page="manage" onclick="navigateTo('manage');closeMenu()" style="color: #333; background: #f7f7f7;"><i data-lucide="lock" style="width:16px; height:16px;"></i></span>
      </div>
     </div>
    </div>
   </nav><!-- PAGE: HOME (Landing with Hero) -->
   <div id="page-home" class="page active">
    <!-- Full-height Hero Section -->
    <section class="hero-gradient relative overflow-hidden w-full" style="min-height: 100vh; display: flex; align-items: center; justify-content: center;">
     <div class="max-w-7xl mx-auto px-6 relative z-10 flex flex-col items-center text-center w-full">
      <h1 id="hero-heading" class="text-6xl md:text-8xl font-extrabold text-white stagger-in" style="text-shadow: 3px 6px 16px rgba(0,0,0,0.2); letter-spacing: -0.02em;">FRESH DROPS</h1>
      <p id="hero-subtext" class="mt-6 text-2xl md:text-3xl text-white/90 max-w-2xl stagger-in font-light" style="animation-delay: 0.15s;">Custom apparel made just for you. Design it, wear it, own it.</p>
      <div id="deals-banner" class="deal-badge mt-10 px-8 py-4 rounded-full font-bold text-lg text-white shadow-lg stagger-in" style="background: linear-gradient(90deg, #FF6B6B, #FFE66D); color: #333; animation-delay: 0.25s;">
       🔥 LIMITED TIME: 30% OFF all custom tees — Use code FRESH30 🔥
      </div>
      <div class="flex flex-col sm:flex-row gap-4 mt-12 stagger-in" style="animation-delay: 0.35s;"><button onclick="navigateTo('catalog')" class="px-10 py-4 rounded-full font-bold text-lg transition-all hover:scale-105 active:scale-95" style="background:#fff; color:#FF6B6B;">Shop Now →</button> <button onclick="navigateTo('deals')" class="px-10 py-4 rounded-full font-bold text-lg transition-all hover:scale-105 active:scale-95 border-2 border-white" style="color:#fff; background:transparent;">View All Deals</button>
      </div>
     </div><!-- Decorative shapes -->
     <svg class="absolute top-0 left-0 w-full h-full opacity-10" preserveaspectratio="none"><circle cx="15%" cy="30%" r="150" fill="white" /><circle cx="85%" cy="70%" r="100" fill="white" /><rect x="60%" y="10%" width="80" height="80" rx="16" fill="white" transform="rotate(30 65 40)" />
     </svg>
    </section>
   </div><!-- PAGE: DEALS -->
   <div id="page-deals" class="page">
    <div class="max-w-7xl mx-auto px-6 py-16">
     <h2 class="text-4xl font-bold mb-4" style="color:#333;">Current Promotions</h2>
     <p class="text-gray-500 mb-10 text-lg">Shop our exclusive deals and limited-time offers on premium apparel.</p>
     <div id="deals-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8"></div>
    </div>
   </div><!-- PAGE: CATALOG -->
   <div id="page-catalog" class="page">
    <div class="max-w-7xl mx-auto px-6 py-12">
     <h2 class="text-3xl font-bold mb-2" style="color:#333;">Full Catalog</h2>
     <p class="text-gray-500 mb-8">Browse all products. Click any item to customize and create a mockup.</p>
     <div class="flex flex-wrap gap-3 mb-8">
      <button onclick="filterCatalog('all')" class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all" style="background:#FF6B6B; color:#fff;">All</button> <button onclick="filterCatalog('tee')" class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all" style="background:#f0f0f0; color:#333;">Tees</button> <button onclick="filterCatalog('hoodie')" class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all" style="background:#f0f0f0; color:#333;">Hoodies</button> <button onclick="filterCatalog('tank')" class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all" style="background:#f0f0f0; color:#333;">Tanks</button> <button onclick="filterCatalog('longsleeve')" class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all" style="background:#f0f0f0; color:#333;">Long Sleeves</button>
     </div>
     <div id="catalog-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8"></div>
    </div>
   </div><!-- PAGE: PRODUCT DETAIL / MOCKUP DESIGNER -->
   <div id="page-product" class="page">
    <div class="max-w-7xl mx-auto px-6 py-12">
     <button onclick="navigateTo(lastCatalogPage)" class="flex items-center gap-2 text-sm font-medium mb-6 hover:opacity-70 transition" style="color:#FF6B6B;"><i data-lucide="arrow-left" style="width:16px;height:16px;"></i> Back</button>
     <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Mockup Preview -->
      <div>
       <div id="mockup-canvas" class="mockup-canvas w-full flex items-center justify-center" style="background: #f0f0f0; min-height: 400px;">
        <div id="mockup-garment" class="relative"></div>
       </div>
       <p class="text-xs text-gray-400 mt-2 text-center">Drag your design text on the garment to reposition</p>
      </div><!-- Product Info & Controls -->
      <div>
       <h2 id="product-title" class="text-3xl font-bold" style="color:#333;"></h2>
       <p id="product-price" class="text-2xl font-bold mt-2" style="color:#FF6B6B;"></p>
       <p id="product-desc" class="text-gray-500 mt-3 leading-relaxed"></p>
       <div class="mt-6 space-y-5">
        <!-- Garment Selector -->
        <div>
         <label class="text-sm font-semibold text-gray-700 block mb-2">Garment Type</label>
         <div id="garment-options" class="flex flex-wrap gap-2"></div>
        </div><!-- Color -->
        <div>
         <label class="text-sm font-semibold text-gray-700 block mb-2">Garment Color</label>
         <div id="color-options" class="flex gap-2"></div>
        </div><!-- Size -->
        <div>
         <label class="text-sm font-semibold text-gray-700 block mb-2">Size</label>
         <div id="size-options" class="flex flex-wrap gap-2"></div>
        </div><!-- Design Text -->
        <div>
         <label class="text-sm font-semibold text-gray-700 block mb-2">Custom Design Text</label> <input type="text" id="mockup-text-input" placeholder="Enter your text..." class="w-full border rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2" style="border-color:#ddd; focus:ring-color:#4ECDC4;" oninput="updateMockupText(this.value)">
        </div><!-- Text Color -->
        <div>
         <label class="text-sm font-semibold text-gray-700 block mb-2">Text Color</label>
         <div class="flex gap-2">
          <button onclick="setTextColor('#FFFFFF')" class="w-8 h-8 rounded-full border-2" style="background:#fff; border-color:#ddd;"></button> <button onclick="setTextColor('#000000')" class="w-8 h-8 rounded-full border-2" style="background:#000; border-color:#333;"></button> <button onclick="setTextColor('#FF6B6B')" class="w-8 h-8 rounded-full border-2" style="background:#FF6B6B; border-color:#FF6B6B;"></button> <button onclick="setTextColor('#FFE66D')" class="w-8 h-8 rounded-full border-2" style="background:#FFE66D; border-color:#FFE66D;"></button> <button onclick="setTextColor('#4ECDC4')" class="w-8 h-8 rounded-full border-2" style="background:#4ECDC4; border-color:#4ECDC4;"></button>
         </div>
        </div><!-- Scale -->
        <div>
         <label class="text-sm font-semibold text-gray-700 block mb-2">Design Size</label> <input type="range" id="mockup-scale" min="0.5" max="3" step="0.1" value="1.5" class="w-full" style="accent-color:#4ECDC4;" oninput="updateMockupScale(this.value)">
        </div><!-- Quantity -->
        <div>
         <label class="text-sm font-semibold text-gray-700 block mb-2">Quantity</label>
         <div class="flex items-center gap-3">
          <button onclick="changeQty(-1)" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-lg" style="background:#f0f0f0; color:#333;">−</button> <span id="qty-display" class="text-lg font-semibold" style="color:#333;">1</span> <button onclick="changeQty(1)" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-lg" style="background:#f0f0f0; color:#333;">+</button>
         </div>
        </div><!-- Add to Cart --> <button id="add-to-cart-btn" onclick="addToCart()" class="w-full py-3 rounded-xl font-bold text-lg text-white transition-all hover:scale-[1.02] active:scale-95" style="background: linear-gradient(90deg, #FF6B6B, #4ECDC4);"> Add to Cart </button>
       </div>
      </div>
     </div>
    </div>
   </div><!-- PAGE: ABOUT -->
   <div id="page-about" class="page active">
    <div class="max-w-4xl mx-auto px-6 py-16">
     <h2 id="about-heading" class="text-4xl font-bold mb-6 stagger-in" style="color:#333;">About Us</h2>
     <div class="rounded-2xl p-8 stagger-in" style="background:#fff; box-shadow: 0 4px 24px rgba(0,0,0,0.06); animation-delay:0.1s;">
      <p id="about-paragraph" class="text-gray-600 leading-relaxed text-lg">We're a custom apparel brand built on creativity, quality, and self-expression. Every piece is designed with care and printed to order so you always get something fresh. From bold graphic tees to cozy hoodies, we make it easy to wear what you love. Our mission is simple: help you stand out and feel amazing in what you wear.</p>
     </div>
     <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-10">
      <div class="rounded-2xl p-6 text-center stagger-in" style="background:#fff; box-shadow: 0 4px 24px rgba(0,0,0,0.06); animation-delay:0.2s;">
       <div class="w-14 h-14 mx-auto rounded-full flex items-center justify-center mb-3" style="background:#FFE66D;"><i data-lucide="zap" style="color:#333; width:24px; height:24px;"></i>
       </div>
       <h3 class="font-bold text-lg" style="color:#333;">Fast Production</h3>
       <p class="text-gray-500 text-sm mt-1">Orders printed and shipped within 48 hours</p>
      </div>
      <div class="rounded-2xl p-6 text-center stagger-in" style="background:#fff; box-shadow: 0 4px 24px rgba(0,0,0,0.06); animation-delay:0.3s;">
       <div class="w-14 h-14 mx-auto rounded-full flex items-center justify-center mb-3" style="background:#4ECDC4;"><i data-lucide="heart" style="color:#fff; width:24px; height:24px;"></i>
       </div>
       <h3 class="font-bold text-lg" style="color:#333;">Made With Love</h3>
       <p class="text-gray-500 text-sm mt-1">Every design is crafted with passion</p>
      </div>
      <div class="rounded-2xl p-6 text-center stagger-in" style="background:#fff; box-shadow: 0 4px 24px rgba(0,0,0,0.06); animation-delay:0.4s;">
       <div class="w-14 h-14 mx-auto rounded-full flex items-center justify-center mb-3" style="background:#FF6B6B;"><i data-lucide="truck" style="color:#fff; width:24px; height:24px;"></i>
       </div>
       <h3 class="font-bold text-lg" style="color:#333;">Free Shipping</h3>
       <p class="text-gray-500 text-sm mt-1">On all regular delivery orders</p>
      </div>
     </div>
    </div>
   </div><!-- PAGE: MANAGE PRODUCTS -->
   <div id="page-manage" class="page"><!-- Login Screen -->
    <div id="manage-login" class="flex items-center justify-center" style="min-height:100vh; background:#FAFAFA;">
     <div class="rounded-2xl p-8 max-w-md w-full mx-4" style="background:#fff; box-shadow: 0 8px 32px rgba(0,0,0,0.08);">
      <h2 class="text-2xl font-bold mb-2 text-center" style="color:#333;">Manage Access</h2>
      <p class="text-gray-500 text-center text-sm mb-6">Enter your password to access the manage section</p><input type="password" id="manage-password" placeholder="Enter password..." class="w-full border rounded-lg px-4 py-3 mb-4 text-sm focus:outline-none focus:ring-2" style="border-color:#ddd; focus:ring-color:#4ECDC4;" onkeypress="if(event.key==='Enter')verifyManagePassword()"> <button onclick="verifyManagePassword()" class="w-full py-3 rounded-lg font-bold text-white transition-all hover:scale-[1.02] active:scale-95" style="background:#4ECDC4;">Access Manage</button> <button onclick="navigateTo('home')" class="w-full mt-2 py-2 rounded-lg font-medium transition-all" style="background:#f0f0f0; color:#333;">Go Back</button>
     </div>
    </div><!-- Manage Dashboard (hidden until password verified) -->
    <div id="manage-dashboard" style="display:none;">
     <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="flex items-center justify-between mb-8">
       <div>
        <h2 class="text-3xl font-bold mb-2" style="color:#333;">Manage Products &amp; Designs</h2>
        <p class="text-gray-500">Add products, create custom designs, and manage your catalog.</p>
       </div><button onclick="logoutManage()" class="px-4 py-2 rounded-lg text-sm font-medium transition-all" style="background:#f0f0f0; color:#333;">Logout</button>
      </div><!-- Tab Navigation -->
      <div class="flex gap-2 mb-8 border-b" style="border-color:#eee;"><button onclick="switchManageTab('products')" class="manage-tab px-4 py-3 font-medium border-b-2 transition-all" data-tab="products" style="border-color:#4ECDC4; color:#4ECDC4;">Products</button> <button onclick="switchManageTab('settings')" class="manage-tab px-4 py-3 font-medium border-b-2 transition-all" data-tab="settings" style="border-color:transparent; color:#999;">Settings</button>
      </div><!-- Products Tab -->
      <div id="tab-products" class="manage-tab-content">
       <div class="rounded-2xl p-6 mb-8" style="background:#f0fffe; border: 2px solid #4ECDC4;">
        <h3 class="font-bold text-lg mb-4" style="color:#333;">Add New Product</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4"><input type="text" id="new-product-code" placeholder="Product Code (e.g. TEEBLUE01)" class="border rounded-lg px-4 py-2 text-sm focus:outline-none" style="border-color:#ddd;"> <input type="text" id="new-product-name" placeholder="Product Name" class="border rounded-lg px-4 py-2 text-sm focus:outline-none" style="border-color:#ddd;"> <input type="text" id="new-product-desc" placeholder="Description" class="border rounded-lg px-4 py-2 text-sm focus:outline-none" style="border-color:#ddd;"> <select id="new-product-category" class="border rounded-lg px-4 py-2 text-sm focus:outline-none" style="border-color:#ddd;"> <option value="">Select Category...</option> <option value="tee">T-Shirt</option> <option value="hoodie">Hoodie</option> <option value="tank">Tank Top</option> <option value="longsleeve">Long Sleeve</option> </select> <input type="number" id="new-product-price" placeholder="Price (e.g. 24.99)" step="0.01" min="0" class="border rounded-lg px-4 py-2 text-sm focus:outline-none" style="border-color:#ddd;"> <input type="number" id="new-product-sale-price" placeholder="Sale Price (optional)" step="0.01" min="0" class="border rounded-lg px-4 py-2 text-sm focus:outline-none" style="border-color:#ddd;"> <input type="text" id="new-product-emoji" placeholder="Emoji (e.g. 🌅)" maxlength="2" class="border rounded-lg px-4 py-2 text-sm focus:outline-none" style="border-color:#ddd;">
        </div><button onclick="addNewProduct()" class="px-6 py-2 rounded-lg font-bold text-white" style="background:#4ECDC4;">Add Product</button>
       </div>
       <h3 class="font-bold text-lg mb-4" style="color:#333;">Your Products</h3>
       <div id="manage-products-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"></div>
      </div><!-- Designs Tab -->
      <div id="tab-settings" class="manage-tab-content" style="display:none;">
       <div class="rounded-2xl p-6" style="background:#f0fffe; border: 2px solid #4ECDC4;">
        <h3 class="font-bold text-lg mb-6" style="color:#333;">Store Settings</h3>
        <div class="space-y-4">
         <div>
          <label class="text-sm font-semibold text-gray-700 block mb-2">Store Name</label> <input type="text" id="setting-store-name" class="w-full border rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2" style="border-color:#ddd;" placeholder="Your Store Name" oninput="updateSetting('store_name', this.value)">
         </div>
         <div>
          <label class="text-sm font-semibold text-gray-700 block mb-2">Tagline</label> <input type="text" id="setting-tagline" class="w-full border rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2" style="border-color:#ddd;" placeholder="Your tagline" oninput="updateSetting('tagline', this.value)">
         </div>
         <div>
          <label class="text-sm font-semibold text-gray-700 block mb-2">Hero Heading</label> <input type="text" id="setting-hero-heading" class="w-full border rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2" style="border-color:#ddd;" placeholder="Main heading text" oninput="updateSetting('hero_heading', this.value)">
         </div>
         <div>
          <label class="text-sm font-semibold text-gray-700 block mb-2">Hero Subtext</label> <input type="text" id="setting-hero-subtext" class="w-full border rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2" style="border-color:#ddd;" placeholder="Subtext under heading" oninput="updateSetting('hero_subtext', this.value)">
         </div>
         <div>
          <label class="text-sm font-semibold text-gray-700 block mb-2">Deals Banner</label> <input type="text" id="setting-deals-banner-text" class="w-full border rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2" style="border-color:#ddd;" placeholder="Current deal announcement" oninput="updateSetting('deals_banner_text', this.value)">
         </div>
         <div>
          <label class="text-sm font-semibold text-gray-700 block mb-2">About Heading</label> <input type="text" id="setting-about-heading" class="w-full border rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2" style="border-color:#ddd;" placeholder="About Us" oninput="updateSetting('about_heading', this.value)">
         </div>
         <div>
          <label class="text-sm font-semibold text-gray-700 block mb-2">About Text</label> <textarea id="setting-about-paragraph" class="w-full border rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2" style="border-color:#ddd; min-height:100px;" placeholder="Tell your story..." oninput="updateSetting('about_paragraph', this.value)"></textarea>

function openProduct(product) {
  currentProduct = product;
  lastCatalogPage = currentPage === 'deals' ? 'deals' : 'catalog';
  mockupState = { garment: product.category, color: '#FFFFFF', size: 'M', text: '', textColor: '#000000', scale: 1.5, qty: 1 };

  document.getElementById('product-title').textContent = product.name;
  document.getElementById('product-price').textContent = '$' + (product.onSale && product.salePrice ? product.salePrice : product.price).toFixed(2);
  document.getElementById('product-desc').textContent = product.desc;
  document.getElementById('mockup-text-input').value = '';
  document.getElementById('mockup-scale').value = 1.5;
  document.getElementById('qty-display').textContent = '1';

  // Garment options
  const gOpts = document.getElementById('garment-options');
  gOpts.innerHTML = '';
  GARMENT_TYPES.forEach(g => {
    const btn = document.createElement('button');
    btn.className = 'px-4 py-2 rounded-full text-sm font-medium transition-all';
    btn.style.cssText = g.id === product.category ? 'background:#4ECDC4; color:#fff;' : 'background:#f0f0f0; color:#333;';
    btn.textContent = g.label;
    btn.onclick = () => { mockupState.garment = g.id; renderGarmentOptions(); renderMockup(); };
    gOpts.appendChild(btn);
  });

  // Color options
  const cOpts = document.getElementById('color-options');
  cOpts.innerHTML = '';
  GARMENT_COLORS.forEach(c => {
    const btn = document.createElement('button');
    btn.className = 'w-9 h-9 rounded-full border-2 transition-all';
    btn.style.cssText = `background:${c.hex}; border-color:${c.hex === mockupState.color ? '#333' : '#ddd'};`;
    btn.title = c.name;
    btn.onclick = () => { mockupState.color = c.hex; renderColorOptions(); renderMockup(); };
    cOpts.appendChild(btn);
  });

  // Size options
  const sOpts = document.getElementById('size-options');
  sOpts.innerHTML = '';
  SIZES.forEach(s => {
    const btn = document.createElement('button');
    btn.className = 'px-4 py-2 rounded-lg text-sm font-medium transition-all';
    btn.style.cssText = s === mockupState.size ? 'background:#333; color:#fff;' : 'background:#f0f0f0; color:#333;';
    btn.textContent = s;
    btn.onclick = () => { mockupState.size = s; renderSizeOptions(); };
    sOpts.appendChild(btn);
  });

  renderMockup();
  navigateTo('product');
  lucide.createIcons();
}


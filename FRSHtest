// ============ GARMENT SVG GENERATORS ============
function garmentSVG(type, color, textStr, textColor, scale) {
  const w = 260, h = 300;
  const textY = type === 'hoodie' ? 175 : 160;
  const fontSize = Math.round(18 * scale);
  const escapedText = (textStr || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  let shape = '';
  switch(type) {
    case 'tee':
      shape = `<path d="M65 60 L30 90 L50 110 L75 90 L75 250 L185 250 L185 90 L210 110 L230 90 L195 60 L170 75 Q130 95 90 75 Z" fill="${color}" stroke="#ccc" stroke-width="1.5"/>`;
      break;
    case 'hoodie':
      shape = `<path d="M60 65 L25 100 L50 120 L70 100 L65 250 L195 250 L190 100 L210 120 L235 100 L200 65 L180 80 Q130 105 80 80 Z" fill="${color}" stroke="#ccc" stroke-width="1.5"/><path d="M105 60 Q130 30 155 60" fill="none" stroke="#ccc" stroke-width="2"/><ellipse cx="130" cy="62" rx="22" ry="10" fill="${color}" stroke="#ccc" stroke-width="1"/>`;
      break;
    case 'tank':
      shape = `<path d="M90 65 L85 70 L80 250 L180 250 L175 70 L170 65 L155 80 Q130 95 105 80 Z" fill="${color}" stroke="#ccc" stroke-width="1.5"/>`;
      break;
    case 'longsleeve':
      shape = `<path d="M65 60 L15 160 L40 170 L75 95 L75 250 L185 250 L185 95 L220 170 L245 160 L195 60 L170 75 Q130 95 90 75 Z" fill="${color}" stroke="#ccc" stroke-width="1.5"/>`;
      break;
  }
  return `<svg viewBox="0 0 ${w} ${h}" width="${w}" height="${h}" xmlns="http://www.w3.org/2000/svg">
    ${shape}
    <text x="130" y="${textY}" text-anchor="middle" font-family="'Space Mono', monospace" font-size="${fontSize}" font-weight="700" fill="${textColor}" style="pointer-events:none;">${escapedText}</text>
  </svg>`;
}

function garmentThumb(type, color, size) {
  const s = size || 60;
  let shape = '';
  switch(type) {
    case 'tee': shape = `<path d="M15 14 L7 21 L12 25 L17 21 L17 50 L43 50 L43 21 L48 25 L53 21 L45 14 L40 17 Q30 23 20 17 Z" fill="${color}" stroke="#ccc" stroke-width="1"/>`; break;
    case 'hoodie': shape = `<path d="M14 15 L5 23 L12 27 L16 23 L15 50 L45 50 L44 23 L48 27 L55 23 L46 15 L42 18 Q30 25 18 18 Z" fill="${color}" stroke="#ccc" stroke-width="1"/><ellipse cx="30" cy="15" rx="6" ry="3" fill="${color}" stroke="#ccc" stroke-width="0.7"/>`; break;
    case 'tank': shape = `<path d="M20 15 L19 16 L18 50 L42 50 L41 16 L40 15 L36 18 Q30 23 24 18 Z" fill="${color}" stroke="#ccc" stroke-width="1"/>`; break;
    case 'longsleeve': shape = `<path d="M15 14 L3 36 L9 38 L17 22 L17 50 L43 50 L43 22 L51 38 L57 36 L45 14 L40 17 Q30 23 20 17 Z" fill="${color}" stroke="#ccc" stroke-width="1"/>`; break;
  }
  return `<svg viewBox="0 0 60 55" width="${s}" height="${s*55/60}" xmlns="http://www.w3.org/2000/svg">${shape}</svg>`;
}


function createProductCard(product, showSale) {
  const price = product.onSale && product.salePrice ? product.salePrice : product.price;
  const card = document.createElement('div');
  card.className = 'product-card rounded-2xl overflow-hidden cursor-pointer';
  card.style.cssText = 'background:#fff; box-shadow: 0 4px 20px rgba(0,0,0,0.06);';
  card.onclick = () => openProduct(product);
  card.innerHTML = `
    <div class="flex items-center justify-center py-8" style="background:#f7f7f7; position:relative;">
      ${product.onSale && showSale ? '<span class="absolute top-3 left-3 px-3 py-1 rounded-full text-xs font-bold text-white" style="background:#FF6B6B;">SALE</span>' : ''}
      <div class="text-6xl">${product.emoji}</div>
    </div>
    <div class="p-5">
      <h3 class="font-bold text-base" style="color:#333;">${product.name}</h3>
      <p class="text-gray-400 text-sm mt-1 truncate">${product.desc}</p>
      <div class="flex items-center gap-2 mt-3">
        <span class="font-bold text-lg" style="color:#FF6B6B;">$${price.toFixed(2)}</span>
        ${product.onSale && product.salePrice ? `<span class="line-through text-gray-400 text-sm">$${product.price.toFixed(2)}</span>` : ''}
      </div>
    </div>`;
  return card;
}

